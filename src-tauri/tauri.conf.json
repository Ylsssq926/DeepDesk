{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepDesk",
  "version": "0.1.0",
  "identifier": "app.deepdesk.unofficial",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "showMenuOnLeftClick": false,
      "tooltip": "DeepDesk · Unofficial"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "© 2026 Ylsssq926 and DeepDesk Contributors. Licensed under AGPL-3.0.",
    "shortDescription": "Unofficial desktop client for chat.deepseek.com",
    "longDescription": "DeepDesk is an unofficial, community-built desktop client for chat.deepseek.com. Not affiliated with DeepSeek.",
    "publisher": "DeepDesk Contributors",
    "homepage": "https://github.com/Ylsssq926/DeepDesk",
    "icon": []
  }
}
