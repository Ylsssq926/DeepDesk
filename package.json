{
  "name": "deepdesk",
  "version": "0.1.0-alpha.0",
  "description": "Unofficial desktop client for chat.deepseek.com — tailor-made for DeepSeek users.",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/Ylsssq926/DeepDesk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ylsssq926/DeepDesk.git"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm build:inject",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "pnpm build:inject && tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "build:inject": "tsx scripts/build-inject.ts",
    "build:inject:watch": "tsx scripts/build-inject.ts --watch",
    "dev:inject": "tsx scripts/build-inject.ts --watch"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.7",
